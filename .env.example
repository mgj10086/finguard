# FinGuard 环境变量配置

# 应用
APP_NAME=FinGuard
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# 数据库 (PostgreSQL)
DATABASE_ENGINE=postgresql
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=finguard
DATABASE_PASSWORD=finguard_secret
DATABASE_NAME=finguard

# 开发环境可用 SQLite
# DATABASE_ENGINE=sqlite
# DATABASE_URL=sqlite+aiosqlite:///./data/finguard.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ALIAS=default
MILVUS_COLLECTION=regulation_chunks

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=finguard_neo4j

# LLM (vLLM/Ollama 兼容 OpenAI API)
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=not-needed
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192

# 备选 LLM (DeepSeek API, 可选)
# FALLBACK_LLM_BASE_URL=https://api.deepseek.com/v1
# FALLBACK_LLM_API_KEY=your-deepseek-key
# FALLBACK_LLM_MODEL_NAME=deepseek-chat

# BGE-M3 嵌入模型
EMBEDDING_MODEL_PATH=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=finguard_minio
MINIO_SECRET_KEY=finguard_minio_secret
MINIO_BUCKET=regulations

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 监控
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
